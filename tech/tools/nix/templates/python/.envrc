use flake

# use flake must stay first — it provides `poetry`. Layer the project's Poetry
# venv on top so console-scripts resolve without a manual activation.
watch_file pyproject.toml poetry.lock
venv="$(poetry env info --path 2>/dev/null || true)"
if [[ -n "$venv" && -d "$venv" ]]; then
  export VIRTUAL_ENV="$venv"
  export POETRY_ACTIVE=1
  PATH_add "$venv/bin"
else
  log_status "Poetry venv not found — run 'poetry install', then 'direnv reload'."
fi
