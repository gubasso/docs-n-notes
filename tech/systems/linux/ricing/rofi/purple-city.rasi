/* Purple City (nova) */
* {
  bg0: #010005;
  bg1: #0B0113;
  bg2: #110326;
  surface0: #16042D;
  surface1: #1C0637;
  overlay0: #2C094C;
  overlay1: #360A55;

  text: #F5F0FF;
  subtext: #D9CCE8;
  muted: #B9A6CC;

  purple_mid: #5D117C;
  accent: #C89DEA;
  accent_glow: #E65FEB;

  success: #3FE1B0;
  warning: #F2D26B;
  error: #FF4D8D;
  info: #7AA2F7;

  font: "JetBrains Mono 12";
  background-color: transparent;
  text-color: @text;
}

window {
  location: center;
  anchor: center;
  fullscreen: false;
  width: 42%;
  padding: 18px;
  border: 2px;
  border-color: @overlay0;
  border-radius: 10px;
  background-color: @surface0;
}

mainbox {
  spacing: 12px;
}

inputbar {
  children: [prompt, entry];
  spacing: 8px;
  padding: 8px 10px;
  border: 1px;
  border-color: @overlay0;
  border-radius: 6px;
  background-color: @bg1;
}

prompt {
  text-color: @accent;
}

entry {
  text-color: @text;
  placeholder: "Search...";
  placeholder-color: @muted;
}

listview {
  columns: 1;
  lines: 9;
  spacing: 6px;
  scrollbar: true;
  padding: 2px 0 0;
}

element {
  padding: 8px 10px;
  border-radius: 6px;
  background-color: transparent;
}

element normal {
  text-color: @text;
}

element active {
  text-color: @text;
  background-color: @surface1;
  border: 1px;
  border-color: @overlay0;
}

element urgent {
  text-color: @error;
  background-color: @surface1;
  border: 1px;
  border-color: @error;
}

element selected {
  text-color: @text;
  background-color: @overlay0;
  border: 1px;
  border-color: @purple_mid;
}

element-icon {
  size: 24px;
  margin: 0 10px 0 0;
}

element-text {
  text-color: inherit;
}

scrollbar {
  handle-width: 8px;
  handle-color: @overlay1;
  background-color: @bg1;
}

mode-switcher {
  spacing: 8px;
}

button {
  padding: 6px 10px;
  border-radius: 6px;
  background-color: @bg1;
  text-color: @subtext;
}

button selected {
  background-color: @accent;
  text-color: @bg0;
}
